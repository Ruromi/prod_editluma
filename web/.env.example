# Vercel 단일 프로젝트 기준 정리본은 ../VERCEL_ENV.md 참고
# ---- Supabase ----
# Project URL (공개 가능)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon key — 브라우저에서 사용 (공개 가능)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — 서버 전용, 절대 브라우저에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# 스키마: 운영은 public 권장, dev 스키마를 쓸 때만 별도 지정
SUPABASE_SCHEMA=public

# ---- API ----
# 운영/Vercel 단일 프로젝트: 둘 다 비워두고 상대 경로(/api/*)를 그대로 사용합니다.
NEXT_PUBLIC_API_URL=
INTERNAL_API_URL=
ADMIN_ALLOWED_IPS=211.204.0.211
ADMIN_EMAILS=oasis_0421@naver.com
# Polar 결제 설정은 api/.env 쪽에서 관리합니다.
